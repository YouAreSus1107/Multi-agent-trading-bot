# ============================================
# WAR-ROOM BOT — Environment Configuration
# Copy this file to .env and fill in your keys
# ============================================

# LLM Provider (auto-failover: Puter -> Groq -> OpenAI -> Gemini)
LLM_PROVIDER=groq

# Puter (FREE + UNLIMITED — https://puter.com, get token from Settings > Developer)
PUTER_API_TOKEN=your-puter-token-here

# Groq (FREE but daily limit — https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI (paid fallback)
OPENAI_API_KEY=sk-your-openai-key-here

# Google Gemini (FREE fallback - https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-key-here

# Alpaca — Broker for trade execution
# Sign up at https://alpaca.markets (paper trading is free)
ALPACA_API_KEY=your-alpaca-api-key
ALPACA_SECRET_KEY=your-alpaca-secret-key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Finnhub — Real-time market data
# Sign up at https://finnhub.io (free tier available)
FINNHUB_API_KEY=your-finnhub-api-key

# Tavily — Agentic web search for news
# Sign up at https://tavily.com (free tier available)
TAVILY_API_KEY=tvly-your-tavily-key-here

# Pinecone — Vector database for war-event patterns
# Sign up at https://pinecone.io (free tier available)
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=war-room-events
